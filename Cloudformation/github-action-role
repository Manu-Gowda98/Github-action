AWSTemplateFormatVersion: '2010-09-09'
Description: IAM Role for GitHub Actions with explicit permissions

Resources:
  GitHubActionsRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: GitHubActionsRole

      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Federated: !Sub arn:aws:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com
            Action: sts:AssumeRoleWithWebIdentity
            Condition:
              StringEquals:
                token.actions.githubusercontent.com:sub: repo:Manu-Gowda98/Github-action:ref:refs/heads/main
                                                     
      Policies:  
        - PolicyName: GitHubActionsPolicy
          PolicyDocument:
            Version: '2012-10-17'
            Statement:

              # EKS Permissions
              - Effect: Allow
                Action:
                  - eks:*
                Resource: "*"

              # EC2 networking required for EKS
              - Effect: Allow
                Action:
                  - ec2:*  
                Resource: "*"

              # S3 Access
              - Effect: Allow
                Action:
                  - s3:GetReplicationConfiguration
                  - s3:GetMetricsConfiguration
                  - s3:GetLifecycleConfiguration
                  - s3:GetInventoryConfiguration
                  - s3:GetIntelligentTieringConfiguration
                  - s3:GetEncryptionConfiguration
                  - s3:GetBucketWebsite
                  - s3:GetBucketVersioning
                  - s3:GetBucketPublicAccessBlock
                  - s3:GetBucketOwnershipControls
                  - s3:GetBucketObjectLockConfiguration
                  - s3:GetBucketNotification
                  - s3:GetBucketLogging
                  - s3:GetBucketCORS
                  - s3:GetBucketAbac
                  - s3:GetAnalyticsConfiguration
                  - GetAccelerateConfiguration
                  - CreateBucket
                Resource: "*"

              # CloudFormation Access
              - Effect: Allow
                Action:
                  - cloudformation:*
                Resource: "*"

              # CodeBuild Access
              - Effect: Allow
                Action:
                  - codebuild:*
                Resource: "*"

              # IAM Read Only
              - Effect: Allow
                Action:
                 - iam:*
                Resource: "*"

              # Pass Role Permission
              - Effect: Allow
                Action:
                  - iam:PassRole
                Resource: "*"

Outputs:
  RoleArn:
    Description: GitHub Actions Role ARN
    Value: !GetAtt GitHubActionsRole.Arn